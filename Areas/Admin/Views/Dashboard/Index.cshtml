@model SureAdmitCore.Areas.Admin.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var userType = Model.UserRole;
}
<head>
<style>
    .bg-paid {
        background: #008b8b8f;
        color: aliceblue;
    }

    .due-card {
        background: #009ecda8;
        color: aliceblue;
    }

    .bg-greens {
        background: #00a65adb;
        color: aliceblue;
    }

    .bg-greene {
        background: #00a4a6;
        color: aliceblue;
    }

    .bg-aquas {
        background: #0095ef;
        color: aliceblue;
    }

    .small-box .icon {
        position: absolute;
        top: 15px;
        right: 10px;
        font-size: 47px;
        transition: all .3s linear;
        color: #fff;
    }

    .small-box:hover .icon {
        font-size: 55px;
    }

    .hcd {
        text-align: center;
        padding: 5px;
        background: cadetblue;
        color: white;
        font-family: serif;
    }

    .small-box {
        border-radius: 5px;
        position: relative;
        overflow: hidden;
        }
       
</style>
</head>
<section class="content"> 
        <div class="row grid-design-box">
            <div class="col-lg-3 col-xs-6">
                <div class="small-box bg-aquas">
                    <div class="inner">
                        <h3>@Model.OPDNewPatients</h3>
                        <p>@DateTime.Now.ToString("MMMM") Total Course</p>
                    </div>
                    <div class="icon"><i class="fa fa-stethoscope"></i></div>
                </div>
            </div>

            <div class="col-lg-3 col-xs-6">
                <a href="/admin/OPD/PatientsDetails">
                    <div class="small-box bg-greens">
                        <div class="inner">
                            <h3>@Model.OPDTotalPatients</h3>
                            <p>Total Patients</p>
                        </div>
                        <div class="icon"><i class="fa fa-wheelchair-alt"></i></div>
                    </div>
                </a>
            </div>  
            <div class="col-lg-3 col-xs-6">
                <a href="/admin/OPD/TodayPatientsDetails">
                    <div class="small-box bg-greene">
                        <div class="inner">
                            <h3>@Model.OPDTodaysPatients</h3>
                            <p>Today Patients</p>
                        </div>
                        <div class="icon"><i class="fa fa-hospital-user"></i></div>
                    </div>
                </a>
            </div>
            </div>
         

</section>
