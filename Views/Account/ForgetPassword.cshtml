@model ForgetPasswordViewModel
@{
    ViewData["Title"] = "Forget Password";
    Layout = null;
} 
<head>
    <title>SureAdmit | Forget Password</title>
    <link rel="icon" href="~/assets/assets/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;family=Lato:wght@100;300;400;700;900&amp;family=Poppins:wght@200;300;400;600;700;800&amp;family=Syncopate:wght@400;700&amp;display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Icon Fonts -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
    <link href="~/assets/css/style.css" rel="stylesheet" />
    <link href="~/assets/css/responsive.css" rel="stylesheet" /> 
    <link href="~/assets/css/forgetpassword.css" rel="stylesheet" />
    <style>

    </style>
</head>

<body>
    <div class="main-banner forget-password-page">
        <div class="d-table">
            <div class="d-table-cell">
                <div class="container">
                    <div class="row align-items-center background-forget-passwrd">
                        <a href="/Account/Login" class="aic" title="Back to Login">
                            <i class="fa fa-arrow-left"></i>
                        </a>

                        <div class="col-lg-12" style="padding-top: 15px;">
                            <div class="logo forgetpaswordlogo">
                                <a href="#">
                                    <img src="~/assets/images/header-logo.png" alt="Logo" />
                                </a>
                            </div>
                        </div>

                        <div class="col-lg-12">
                            <div class="banner-form ml-3">
                                <h2>Forget Password</h2>
                                <p>Enter your registered Email to reset your password.</p>

                                <form asp-action="ForgetPassword" method="post" autocomplete="off">

                                    <!-- Email Field -->
                                    <div class="form-group input_focus value_focus">
                                        <label asp-for="Email"></label>
                                        @if (ViewData["IsOTPSent"] != null)
                                        {
                                            <div class="input-wrap">
                                                <input asp-for="Email" class="form-control" autocomplete="off" readonly />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="input-wrap">
                                                <input asp-for="Email" class="form-control" autocomplete="off" />
                                            </div>
                                        }
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>

                                    <!-- Send OTP Button (only before OTP is sent or after expiry) -->
                                    @if (ViewData["IsOTPSent"] == null || ViewData["IsOTPExpired"] != null)
                                    {
                                        <button type="submit" name="actionType" value="SendOTP" class="btn btn-primary mt-2 otpbtton">
                                            @(ViewData["IsOTPExpired"] != null ? "Resend OTP" : "Send OTP")
                                        </button>
                                    }

                                    <!-- OTP & Reset Password Fields (only if OTP is sent and not expired) -->
                                    @if (ViewData["IsOTPSent"] != null && ViewData["IsOTPExpired"] == null)
                                    {
                                        <div class="form-group mt-3">
                                            <label asp-for="OTP"></label>
                                            <div class="input-wrap">
                                                <input asp-for="OTP" class="form-control" autocomplete="off" />
                                            </div>
                                            <span asp-validation-for="OTP" class="text-danger"></span>
                                        </div>

                                        <div class="form-group mt-3">
                                            <label asp-for="NewPassword"></label>
                                            <div class="input-wrap">
                                                <input asp-for="NewPassword" type="password" class="form-control" id="NewPassword" autocomplete="new-password" />
                                            </div>
                                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                                        </div>

                                        <div class="form-group mt-3">
                                            <label asp-for="ConfirmPassword"></label>
                                            <div class="input-wrap">
                                                <input asp-for="ConfirmPassword" type="password" class="form-control" id="ConfirmPassword" autocomplete="new-password" oninput="checkPasswordMatch()" />
                                            </div>
                                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                            <div id="passwordMatchMessage" style="font-weight: bold; margin-top: 5px;"></div>
                                        </div>

                                        <div class="form-group mt-2" id="divShowPassword">
                                            <input type="checkbox" id="cbShowHidePassword" onclick="togglePasswordVisibility()" />
                                            <span for="cbShowHidePassword">Show Password</span>
                                        </div>

                                        <button type="submit" name="actionType" value="ResetPassword" class="btn btn-success mt-3 otpbtton">Reset Password</button>
                                    }
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Message"] != null)
    {
        <script>
            Swal.fire({
                icon: '@TempData["MessageType"]',
                title: '@TempData["Message"]',
                showConfirmButton: true,
                confirmButtonText: 'OK'
            });
        </script>
    }

    <script>
        function checkPasswordMatch() {
            var pass = document.getElementById('NewPassword').value;
            var confirmPass = document.getElementById('ConfirmPassword').value;
            var message = document.getElementById('passwordMatchMessage');

            if (!pass && !confirmPass) {
                message.innerText = '';
                return;
            }

            if (pass === confirmPass) {
                message.style.color = "green";
                message.innerText = "Passwords match.";
            } else {
                message.style.color = "red";
                message.innerText = "Passwords do not match!";
            }
        }

        function togglePasswordVisibility() {
            var pass = document.getElementById('NewPassword');
            var confirmPass = document.getElementById('ConfirmPassword');
            var checkbox = document.getElementById('cbShowHidePassword');

            if (checkbox.checked) {
                pass.type = "text";
                confirmPass.type = "text";
            } else {
                pass.type = "password";
                confirmPass.type = "password";
            }
        }
    </script>
    <script>
                jQuery('input[type!="submit"], textarea,select').focusin(function () {
            jQuery(this).parent().parent().addClass("input_focus");
            jQuery(".submit-btn input").parent().parent().removeClass("input_focus");
        })
            .focusout(function () {
                jQuery(this).parent().parent().removeClass("input_focus");
            });

        jQuery('input[type!="submit"], textarea,select').change(function () {
            if (jQuery(this).val() != "") {
                jQuery(this).parent().parent().addClass("value_focus");
            } else {
                jQuery(this).parent().parent().removeClass("value_focus");
            }
        });
    </script>
</body>