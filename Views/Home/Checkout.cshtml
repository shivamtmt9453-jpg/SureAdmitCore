                                </div>
                                <span asp-validation-for="BachelorCGPA" class="text-danger"></span>
                            </div>

                            <div class="form-group" style="display:none;">
                                <label for="MasterCGPA">Master’s CGPA/%</label>
                                <div class="input-wrap">
                                    <input asp-for="MasterCGPA" autocomplete="off" class="form-control" maxlength="5" />
                                </div>
                                <span asp-validation-for="MasterCGPA" class="text-danger"></span>
                            </div>

                            <div class="form-group" style="display:none;">
                                <label for="GREVerbal">GRE Verbal Test Score</label>
                                <div class="input-wrap">
                                    <input asp-for="GREVerbal" autocomplete="off" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group" style="display:none;">
                                <label for="GREQuant">GRE Quantitative Test Score</label>
                                <div class="input-wrap">
                                    <input asp-for="GREQuant" autocomplete="off" class="form-control" />
                                </div>
                            </div>

                           

                            @if (Model.CartCourses != null && Model.CartCourses.Any())
                            {
                                var firstCoursePrice = Model.CartCourses.FirstOrDefault()?.CoursePriceDisplay ?? "₹0.00";
                                var firstCurrencySymbol = firstCoursePrice.FirstOrDefault();
                                var isINR = firstCurrencySymbol == '₹';
                                var isUSD = firstCurrencySymbol == '$';
                                <div class="form-group currency input_focus value_focus">
                                    <label for="Currency">Currency</label>
                                    <div class="input-wrap selectarow">
                                        <select id="Currency" asp-for="SelectedCurrency" class="form-select">
                                            <option value="USD">$ USD</option>
                                            <option value="INR">₹ INR</option>
                                        </select>
                                    </div>
                                </div>

                                <div id="CartCoursesList" class="form-group">
                                    @foreach (var course in Model.CartCourses)
                                    {
                                        <div class="course-row mb-2">
                                            <div class="form-group input_focus value_focus">
                                                <label>Course</label>
                                                <div class="input-wrap">
                                                    <input type="text" autocomplete="off" class="form-control mb-1" value="@course.CourseName" readonly />
                                                </div>
                                            </div>
                                            <div class="form-group input_focus value_focus">
                                                <label>Course Price</label>
                                                <div class="input-wrap">
                                                    <input type="text" autocomplete="off" class="form-control price-field" value="@course.CoursePriceDisplay" readonly />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                              

                                <!-- Display Totals -->
                                <div class="form-group input_focus value_focus">
                                    <label>Subtotal</label>
                                    <div class="input-wrap">
                                        <input type="text" id="Subtotal" class="form-control" readonly />
                                        <input type="hidden" autocomplete="off" asp-for="Subtotal" id="SubtotalHidden" />
                                    </div>

                                </div>
                                <div class="form-group input_focus value_focus">
                                    <label>GST (18%)</label>
                                    <div class="input-wrap">
                                        <input type="text" id="GST" class="form-control" readonly />
                                        <input type="hidden" autocomplete="off" asp-for="GST" id="GstHidden" />
                                    </div>

                                </div>
                                <div class="form-group input_focus value_focus">
                                    <label>Total</label>
                                    <div class="input-wrap">
                                        <input type="text" id="Total" class="form-control" readonly />
                                        <input type="hidden" autocomplete="off" asp-for="Total" id="TotalHidden" />
                                    </div>

                                </div>
                            }
                            else
                            {
                                <p>No courses in cart.</p>
                            }
                            <div class="col-12 mt-3 submitbutton">
                                <button type="submit" >Continue to Pay</button>
                            </div>
                        </div>

