    <script>
        $(document).ready(function () {
            function calculateTotals() {
                var priceFields = document.querySelectorAll(".price-field");
                if (!priceFields.length) return;

                var currencyDropdown = document.getElementById("Currency");
                var selectedCurrency = currencyDropdown.value; // "INR" or "USD"
                var conversionRate = 90; // 1 USD = 90 INR

                var subtotal = 0;

                priceFields.forEach(function (input) {
                    var valueStr = input.value.replace(/[^0-9.,]/g, ''); // remove symbols
                    valueStr = valueStr.replace(/,/g, ''); // remove commas
                    var num = parseFloat(valueStr) || 0;

                    // Convert USD → INR if needed
                    if (input.value.charAt(0) === '$' && selectedCurrency === "INR") {
                        num *= conversionRate;
                    }
                    // Convert INR → USD if needed
                    if (input.value.charAt(0) === '₹' && selectedCurrency === "USD") {
                        num /= conversionRate;
                    }

                    subtotal += num;
                });

                var gst = (selectedCurrency === "INR") ? subtotal * 0.18 : 0;
                var total = subtotal + gst;

                var symbol = selectedCurrency === "INR" ? "₹" : "$";

                // Update visible inputs
                document.getElementById("Subtotal").value = symbol + subtotal.toFixed(2);
                document.getElementById("GST").value = symbol + gst.toFixed(2);
                document.getElementById("Total").value = symbol + total.toFixed(2);

                // Update hidden inputs for POST
                document.getElementById("SubtotalHidden").value = subtotal.toFixed(2);
                document.getElementById("GstHidden").value = gst.toFixed(2);
                document.getElementById("TotalHidden").value = total.toFixed(2);
            }

            // Initial calculation
            calculateTotals();

            // Recalculate on currency change
            $("#Currency").on("change", calculateTotals);
        });
    </script>
    <script>
                jQuery('input[type!="submit"], textarea,select').focusin(function () {
            jQuery(this).parent().parent().addClass("input_focus");
            jQuery(".submit-btn input").parent().parent().removeClass("input_focus");
        })
            .focusout(function () {
                jQuery(this).parent().parent().removeClass("input_focus");
            });

        jQuery('input[type!="submit"], textarea,select').change(function () {
            if (jQuery(this).val() != "") {
                jQuery(this).parent().parent().addClass("value_focus");
            } else {
                jQuery(this).parent().parent().removeClass("value_focus");
            }
        });
    </script>
