                            </div>

                            <div class="form-group">
                                <label for="Phone">Phone*</label>
                                <div class="input-wrap">
                                    <input asp-for="Phone" autocomplete="off"  type="tel" maxlength="15" class="form-control" required />
                                </div>
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            
                      

                            <div class="form-group">
                                <label for="Address">Address*</label>
                                <div class="input-wrap">
                                    <input asp-for="Address" autocomplete="off" class="form-control" type="text" required />
                                </div>
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label for="PinCode">Pin Code*</label>
                                <div class="input-wrap">
                                    <input asp-for="PinCode"
                                           type="text"
                                           maxlength="6"
                                           autocomplete="off"
                                           class="form-control"
                                           required
                                           oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                                           pattern="\d{6}"
                                           title="Pin Code must be exactly 6 digits" />
                                </div>
                                <span asp-validation-for="PinCode" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label for="City">City*</label>
                                <div class="input-wrap">
                                    <input asp-for="City" autocomplete="off" class="form-control" type="text" required />
                                </div>
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>

                                
                            <div class="form-group input_focus value_focus">
                                <label for="State">State*</label>
                                <div class="input-wrap selectarow">
