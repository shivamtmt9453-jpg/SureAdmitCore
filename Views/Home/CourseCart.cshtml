@model List<SureAdmitCore.Areas.Admin.Models.Course>
@using System.Text.RegularExpressions
@{
    ViewData["Title"] = "Course Cart";
    Layout = null;
}

<head>
    <title>Course Cart</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="~/assets/images/favicon.png" />
    <link href="~/assets/css/fees-payment.css" rel="stylesheet" />
    <link href="~/assets/css/fees-pay-responsive.css" rel="stylesheet" />
    <link href="~/assets/css/cartpage.css" rel="stylesheet" />

    <style>
        .custom-modal {
            display: none;
            position: fixed;
            z-index: 999;
            padding-top: 50px;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
        }

        .modal-content {
            background: #fff;
            margin: auto;
            padding: 20px;
            width: 60%;
            border-radius: 10px;
            text-align: center;
            max-height: 80vh;
            overflow-y: auto;
        }

        

            .modal-content img {
                max-width: 100%;
                height: auto;
                margin-bottom: 15px;
            }

        .close-btn {
            float: right;
            font-size: 24px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <header class="header" id="header">
        <div class="container">
            <div class="big-wrap-of-logo-menu">
                <div class="logo-wrap">
                    <a href="/home/scholaria">
                        <img src="~/assets/images/header-logo.png" />
                    </a>
                </div>
                <div class="menu-wrap-menu">
                </div>
            </div>
        </div>
    </header>
    <main class="maincoursecart">
        <section class="cartpagewrrap">
            <div class="container">

                <!-- Cart Items -->
                <div class="cart-items">
                    @if (!Model.Any())
                    {
                        <p>No courses in cart.</p>
                    }
                    else
                    {
                      

                    @foreach (var course in Model)
                        {
                            var plainText = Regex.Replace(course.CourseDescription ?? "", "<.*?>", "");
                            var shortDesc = plainText.Length > 150 ? plainText.Substring(0, 150) + "..." : plainText;

                            <div class="cart-item">
                                <img src="@course.CourseImgPath" />

                                <div class="item-details">
                                    <h4>@course.CourseName</h4>

                                    <!-- ✅ Short Description -->
                                    <p class="short-desc">@shortDesc</p>

                                    <!-- ✅ Read More Button -->
                                    <button class="read-more-btn"
                                            data-name="@course.CourseName"
                                            data-img="@course.CourseImgPath"
                                            data-desc='@Html.Raw(course.CourseDescription)'>
                                        Read More
                                    </button>

                                    <div class="classpricewrrap">
                                        <div class="priceheightlight">Price :</div>
                                        <div class="price">@course.CoursePrice</div>
                                    </div>

                                    <div class="remove common-btn-desgn">
                                        <a asp-action="RemoveFromCart"
                                           asp-route-courseId="@course.CourseId"
                                           class="btn btn-danger btn-sm">
                                            Remove
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Summary -->
                <div class="summary">
                    <h3>Course Summary</h3>

                    @{

                        decimal subtotal = 0;
                        string currencySymbol = "";

                        foreach (var c in Model)
                        {
                            if (!string.IsNullOrEmpty(c.CoursePrice))
                            {
                                // Set currency symbol from first course
                                if (string.IsNullOrEmpty(currencySymbol))
                                    currencySymbol = c.CurrencySymbol ?? "$";

                                // Remove non-numeric chars except dot
                                var cleanPrice = new string(c.CoursePrice.Where(ch => char.IsDigit(ch) || ch == '.').ToArray());

                                if (decimal.TryParse(cleanPrice, out var price))
                                    subtotal += price;
                            }
                        }

                        decimal discount = 0; // add your logic if needed
                        decimal total = subtotal - discount;
                    }

                    <p><span>Subtotal</span><span>@currencySymbol@subtotal.ToString("N2")</span></p>
                    <p><span>Discount</span><span>@currencySymbol@discount.ToString("N2")</span></p>
                    <hr>
                    <p class="total"><span>Total</span><span>@currencySymbol@total.ToString("N2")</span></p>

                    <a asp-action="Checkout" class="checkout">Proceed to Checkout</a>
                </div>

            </div>
        </section>
    </main>
    <!-- footer start -->
    <footer class="footer widget-footer clearfix">
        <div class="container">
            <div class="wrapper">
                <div class="widget-area first-box-footer">
                    <div id="block-13" class="widget widget_block widget_media_image">
                        <a href="/Home/feespaymentstructure">
                            <img loading="lazy" decoding="async" src="~/assets/images/header-logo.png" alt="" class="wp-image-3840">
                        </a>
                    </div>
                    <div id="block-14" class="widget widget_block widget_text">
                        <p>
                            <strong>Your Roadmap to Success</strong><br />
                            Harness our 25+ years of accomplished experience to simplify your admissions journey,
                            while maximizing your admit and scholarship probabilities.
                        </p>
                    </div>
                    <div id="block-15" class="widget widget_block widget_text">
                        <p>
                            <img loading="lazy" decoding="async" width="124" height="41" class="wp-image-149" style="width: 124px;" src="https://themes.getmotopress.com/coachzee-teacher/wp-content/uploads/sites/47/2022/01/sign-light.svg" alt="">
                        </p>
                    </div>
                </div>
                <div class="widget-area">
                    <div id="block-16" class="widget widget_block">
                        <h3 class="wp-block-heading">Book a session Today</h3>
                    </div>
                    <div id="block-17" class="widget widget_block widget_text">
                        <p>Discover Scholarships and Foreign Universities with us and take the class leading counselling for free, Today!</p>
                    </div>

                </div>
                <div class="widget-area">
                    <div id="block-18" class="widget widget_block">
                        <h3 class="wp-block-heading">Get in Touch </h3>
                    </div>
                    <div id="block-19" class="widget widget_block">
                        <div class="custom-table">
                            <div class="custom-table-item">
                                <img class="png-icon-design" src="~/assets/images/fees-call.png" />
                                <span class="custom-table-value">
                                    <a href="tel:+919810010113">+91-98100 10113</a><br />
                                    <a href="tel:+1(833)3276640">+1 (833) 327 6640</a>
                                </span>
                            </div>
                            <div class="custom-table-item">
                                <img class="png-icon-design" src="~/assets/images/fees-mail.png" />
                                <span class="custom-table-value">
                                    <a href="mailto:enquiry@sureadmit.com">enquiry@sureadmit.com</a>
                                </span>
                            </div>
                            <div class="custom-table-item">
                                <img class="png-icon-design" src="~/assets/images/fees-address.png" />
                                <span class="custom-table-value">
                                    101-B, Grover Chambers, 4-B Pusa Road,<br />
                                    New Delhi 110005, India
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="copyright-text">
            <div class="container">
                <div class="wrapper">
                    <div class="site-info">
                        SureAdmit © 2026 - All Rights Reserved
                    </div>

                </div>
            </div>
        </div>
    </footer>
    <!-- footer end -->
</body>

<div id="courseModal" class="custom-modal">
    <div class="modal-content">
        <span class="close-btn">×</span>
        <div class="row">
        <!-- Image Section -->
        <div class="col-sm-6 modal-img-wrap">
            <img id="modalImg" src="" alt="Course Image" />
        </div>

        <!-- Details Section -->
            <div class="col-sm-6 modal-details">
            <h2 id="modalTitle"></h2>
            <div id="modalDesc"></div> <!-- HTML content goes here -->
        </div>
        </div>
    </div>
</div>

    <script>
        const modal = document.getElementById("courseModal");
        const modalTitle = document.getElementById("modalTitle");
        const modalImg = document.getElementById("modalImg");
        const modalDesc = document.getElementById("modalDesc");
        const closeBtn = document.querySelector(".close-btn");

        document.querySelectorAll(".read-more-btn").forEach(btn => {
            btn.addEventListener("click", function () {

                modal.style.display = "block";
                modalTitle.innerText = this.dataset.name;
                modalImg.src = this.dataset.img;

                // 🔥 CKEditor HTML render
                modalDesc.innerHTML = this.dataset.desc;
            });
        });

        closeBtn.onclick = function () {
            modal.style.display = "none";
        };

        window.onclick = function (e) {
            if (e.target == modal) {
                modal.style.display = "none";
            }
        };
    </script>
